# Sonarr Configuration (required)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Sonarr Series Defaults
SONARR_ROOT_FOLDER=/tv/anime
SONARR_QUALITY_PROFILE=HD-1080p
SONARR_SERIES_TYPE=anime
SONARR_MONITOR=all
SONARR_SEASON_FOLDER=true
SONARR_SEARCH_ON_ADD=false
SONARR_TAGS=

# TheTVDB API Key (recommended - direct TVDB search)
# Get a free project key at https://thetvdb.com/dashboard/account/apikey
TVDB_API_KEY=

# TMDB API Key (optional - fallback for ID mapping)
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Flask
FLASK_PORT=5656
